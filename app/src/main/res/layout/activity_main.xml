<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml  —  VERSIÓN COMPLETA
    Layout vertical:
      ┌────────────────────────────────┐
      │   Vista de cámara              │  (ocupa todo el espacio sobrante)
      ├────────────────────────────────┤
      │  FPS        [Karl Struss] [Chroma Key]  │  (botones de modo)
      │  Etiqueta de estado            │
      ├────────────────────────────────┤
      │  Panel Karl Struss  (visible)  │  ← se alterna con Panel Chroma
      │   o                            │
      │  Panel Chroma Key  (oculto)    │
      └────────────────────────────────┘
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- Vista de la cámara — ocupa todo el espacio disponible arriba      -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <org.opencv.android.JavaCameraView
        android:id="@+id/camera_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- Panel de control inferior                                          -->
    <!-- ══════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#DD111111"
        android:padding="10dp">

        <!-- Fila superior: FPS + botones de modo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_fps"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="FPS: --"
                android:textColor="#00FF00"
                android:textSize="13sp"
                android:fontFamily="monospace" />

            <Button
                android:id="@+id/btn_modo_karl"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Karl Struss"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1565C0"
                android:layout_marginEnd="6dp"/>

            <Button
                android:id="@+id/btn_modo_chroma"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Chroma Key"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#424242"/>

        </LinearLayout>

        <!-- Etiqueta de estado dinámico -->
        <TextView
            android:id="@+id/tv_estado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="..."
            android:textColor="#AAAAAA"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginTop="4dp"/>

        <!-- ─────────────────────────────────────────────────────────────── -->
        <!-- PANEL MODO 1: Karl Struss                                       -->
        <!-- ─────────────────────────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/panel_karl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp"
            android:visibility="visible">

            <TextView
                android:id="@+id/tv_alpha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="α = 0.50"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:gravity="center"
                android:fontFamily="monospace"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Azul" android:textColor="#6699FF" android:textSize="12sp"/>
                <SeekBar
                    android:id="@+id/seek_alpha"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="8dp"
                    android:max="100"
                    android:progress="50"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Rojo" android:textColor="#FF6666" android:textSize="12sp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- ─────────────────────────────────────────────────────────────── -->
        <!-- PANEL MODO 2: Chroma Key + Ruido + Filtro                      -->
        <!-- ─────────────────────────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/panel_chroma"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp"
            android:visibility="gone">

            <!-- Fila de switches -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Fondo" android:textColor="#CCCCCC" android:textSize="10sp"/>
                    <Switch android:id="@+id/switch_fondo"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textOn="Azul" android:textOff="Verde" android:textColor="#FFFFFF"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Tipo Ruido" android:textColor="#CCCCCC" android:textSize="10sp"/>
                    <Switch android:id="@+id/switch_ruido"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textOn="Speckle" android:textOff="Gauss" android:textColor="#FFFFFF"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Tipo Filtro" android:textColor="#CCCCCC" android:textSize="10sp"/>
                    <Switch android:id="@+id/switch_filtro"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textOn="Gaussiano" android:textOff="Mediana" android:textColor="#FFFFFF"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Slider: Media del ruido (0–100) -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Media del ruido:" android:textColor="#CCCCCC" android:textSize="11sp"/>
            <SeekBar android:id="@+id/seek_media"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:max="100" android:progress="0"/>

            <!-- Slider: Varianza del ruido (0–2000) -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Varianza del ruido:" android:textColor="#CCCCCC" android:textSize="11sp"
                android:layout_marginTop="4dp"/>
            <SeekBar android:id="@+id/seek_varianza"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:max="2000" android:progress="500"/>

            <!-- Slider: Kernel del filtro (3–20) -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Tamaño kernel filtro:" android:textColor="#CCCCCC" android:textSize="11sp"
                android:layout_marginTop="4dp"/>
            <SeekBar android:id="@+id/seek_kernel"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:max="20" android:progress="5"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>